# App
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Database
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/cryptoai.db
# PostgreSQL (uncomment when scaling up)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cryptoai

# Cache
# 'memory' for simple in-process dict, 'redis' for Redis cache
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Personal use: set your Telegram User ID to restrict access
TELEGRAM_ALLOWED_USER_ID=123456789

# AI Providers (Hybrid)
PRIMARY_AI_PROVIDER=claude          # claude | openai
FAST_AI_PROVIDER=deepseek           # deepseek | openai
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-proj-xxx
DEEPSEEK_API_KEY=sk-dsk-xxx

# Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# External APIs
CRYPTOPANIC_API_KEY=xxx

# Trading Defaults
DEFAULT_CAPITAL_USD=1000.0
DEFAULT_RISK_PER_TRADE=0.02
DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
MORNING_BRIEF_TIME=07:00

# Rate limits
MAX_AI_CALLS_PER_MINUTE=5
MAX_ALERTS_PER_COIN_PER_HOUR=3
MAX_SIGNAL_CALLS_PER_HOUR=10
